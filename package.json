{
  "name": "maho-storefront-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:sync": "node scripts/build-extensions.mjs",
    "docs:pdf": "node scripts/extensions-pdf.mjs",
    "dev": "npm run docs:sync && vitepress dev",
    "build": "npm run docs:sync && vitepress build && npm run docs:pdf",
    "preview": "vitepress preview",
    "deploy": "npm run build && wrangler pages deploy .vitepress/dist --project-name maho-storefront-docs --branch main"
  },
  "devDependencies": {
    "mermaid": "^11.4.1",
    "vitepress": "^1.6.3",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
